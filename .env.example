# 个人知识库系统环境变量示例
# 复制本文件为 .env 后按需修改；不要提交真实 .env。

# 项目/数据根目录，默认当前工作目录
PKB_ROOT=/Users/zxz/Workspace/personal_knowledge_base

# LLM 上下文窗口大小；分块大小为该值的 1/4
PKB_LLM_CONTEXT_WINDOW=4096

# 统一 API Key / Base URL；模块专用配置为空时会回退读取这两个变量
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM 远程模式：OpenAI-compatible Chat Completions API
PKB_LLM_PROVIDER=openai-compatible
PKB_LLM_MODEL=your_chat_model_here
PKB_LLM_API_KEY=
PKB_LLM_BASE_URL=
PKB_LLM_TIMEOUT=60

# Embedding 远程模式：OpenAI-compatible Embeddings API
PKB_EMBEDDING_PROVIDER=openai-compatible
PKB_EMBEDDING_MODEL=your_embedding_model_here
PKB_EMBEDDING_DIMENSION=64
PKB_EMBEDDING_API_KEY=
PKB_EMBEDDING_BASE_URL=
PKB_EMBEDDING_TIMEOUT=30
